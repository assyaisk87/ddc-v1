{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "outDir": "../../.netlify/functions-build",
    "rootDir": "../../",
    "sourceMap": true,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": ["*.ts", "../../shared/**/*.ts"],
  "exclude": ["node_modules"]
}

